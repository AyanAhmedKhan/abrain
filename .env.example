# gbrain · worker environment
# Use the DIRECT Supabase connection (db.<project-ref>.supabase.co:5432)
# or the SESSION-mode pooler — not transaction mode (breaks long-lived
# worker loops / pgmq visibility semantics).
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres

# LLM gate threshold (build spec §8). Tune via skip rate, not gut.
SIGNAL_THRESHOLD=0.35

# Sweeper grace period before re-enqueueing orphaned gb_raw rows (minutes)
SWEEPER_GRACE_MINUTES=5

# ── Phase 1 (not used yet, reserved) ────────────────────────
# ANTHROPIC_API_KEY=
# EXTRACT_MODEL=claude-haiku-4-5-20251001   # extraction
# EMBED_MODEL=gemini-embedding-001          # via Vertex, output_dimensionality=768
# MAX_BATCH=50
# MAX_WAIT_MINUTES=30

# ── M1: storage + Gemini ─────────────────────────────────────
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_KEY=eyJ...        # Settings → API → service_role (server-only!)
BRONZE_BUCKET=gbrain-bronze

# Gemini auth — EITHER an AI Studio key:
GEMINI_API_KEY=
# OR Vertex (burns credits): uncomment all three
# GOOGLE_GENAI_USE_VERTEXAI=true
# GOOGLE_CLOUD_PROJECT=your-project
# GOOGLE_CLOUD_LOCATION=asia-south1

EXTRACT_MODEL=gemini-2.5-flash
ESCALATE_MODEL=gemini-2.5-pro
EMBED_MODEL=gemini-embedding-001
EMBED_DIMS=768

# Gmail classifier — your "Call Notes" Gmail label ID(s), comma-separated.
# Find it: Gmail Settings → Labels, or via the API. Optional — rules work without it.
GMAIL_DEAL_LABEL_IDS=

# Pitch decks (image/chart-heavy PDFs are read by Gemini vision in extract.py).
# DECK_VISION=all forces vision even for decks that DO have a text layer (max
# accuracy on chart/table decks). Empty/unset = vision only when no text layer.
DECK_VISION=
# Cap on per-page vision-caption chunks per deck (page-level retrieval/citations).
DECK_MAX_PAGES=40
# Optional daily LLM spend rail (USD); 0/empty = unlimited. Only extract.py spends.
LLM_DAILY_BUDGET_USD=25
