[Unit]
Description=Tracxn -> gbrain extractor
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
# adjust user / paths to your VPS
User=tracxn
WorkingDirectory=/opt/tracxn/vps
EnvironmentFile=/etc/tracxn.env
ExecStart=/opt/tracxn/vps/.venv/bin/python tracxn_pull.py --ids-file universe.txt --resume
# keep noise down; logs go to the journal
StandardOutput=journal
StandardError=journal
Nice=10

[Install]
WantedBy=multi-user.target
