# ============================================================================
# Tracxn -> gbrain extractor — environment configuration
# Copy to ".env" (or an /etc/tracxn.env systemd EnvironmentFile) and fill in.
# NOTHING here is committed; keep this file 0600 and out of git.
# ============================================================================

# ---- Tracxn auth: PRIMARY = exported session ------------------------------
# Capture once in a real browser:  python -m tracxn.client login
# (writes storage_state.json) — then copy that file to the VPS.
TRACXN_STORAGE_STATE=storage_state.json
# ...or paste a raw Cookie header instead of a storage_state file:
# TRACXN_COOKIE=key1=val1; key2=val2

# ---- Tracxn auth: FALLBACK = headless login (refreshes the cookie) --------
# Used automatically when the session expires. Leave blank to disable.
TRACXN_EMAIL=
TRACXN_PASSWORD=
TRACXN_LOGIN_FALLBACK=1
TRACXN_LOGIN_URL=https://platform.tracxn.com/a/login

# ---- politeness / safety (datacenter IPs get flagged — keep it slow) ------
TRACXN_DELAY_MS=1500
TRACXN_MAX_RETRIES=3
TRACXN_BACKOFF_MS=2000
TRACXN_TIMEOUT_S=30
# Strongly recommended on a VPS: route via a residential proxy.
# TRACXN_PROXY=http://user:pass@residential-proxy:port

# ---- output ----------------------------------------------------------------
TRACXN_JSONL=out/tracxn.jsonl
TRACXN_STATE=out/processed_ids.txt

# ---- gbrain REST / webhook sink -------------------------------------------
GBRAIN_WEBHOOK_URL=https://gbrain.your-domain/ingest
GBRAIN_API_KEY=
GBRAIN_AUTH_HEADER=Authorization
GBRAIN_AUTH_SCHEME=Bearer
GBRAIN_BATCH=1          # companies per POST (1 = one at a time)
GBRAIN_DRY_RUN=0        # 1 = log instead of POST (useful for first run)
