# ───────────────────────────────────────────────────────────────
# gbrain .gitignore
# Rule of thumb: track source + manifests + .example templates.
# Never track secrets, virtualenvs, dependencies, data, or generated artifacts.
# ───────────────────────────────────────────────────────────────

# ── Secrets & credentials (NEVER commit) ──────────────────────────
# Real env files; templates stay tracked (see un-ignore below).
.env
.env.*
*.env
dashboard/.env.local

# Service accounts, OAuth, API keys, tokens
client_secret*.json
*-sa.json
vertex-sa.json
credentials*.json
service-account*.json
tokens/
*token*.json

# TLS / SSH / signing material
*.pem
*.key
*.crt
*.p12
*.pfx
id_rsa*

# Syncthing (device certs + keys + local db)
.config/syncthing/

# Keep example/template env files tracked
!.env.example
!.env.*.example
!*.env.example

# ── Python ────────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
dist/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.python-version

# ── Node / dashboard ──────────────────────────────────────────────
node_modules/
.next/
out/
.turbo/
*.tsbuildinfo
next-env.d.ts
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ── Data, vaults & large/binary artifacts ─────────────────────────
# Knowledge-base data and ingest payloads are not source.
/vault/
/Obsidian/
*.zip
*.pdf
*.sqlite
*.sqlite3
*.db

# Exported / generated graph data
viewer/graph.json
graph.json
*.export.json

# ── Logs & runtime ────────────────────────────────────────────────
*.log
logs/
*.pid
*.seed
*.out
tmp/
.tmp/

# ── OS & editor cruft ─────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
*.swp
*.swo
*~
.idea/
.vscode/
!.vscode/extensions.json
